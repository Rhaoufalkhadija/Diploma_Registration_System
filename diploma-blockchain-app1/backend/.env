# ─────────────────────────────────────────────
#  .env.example — Backend DiplomaRegistry
#  Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────

# URL du nœud Ethereum (local Hardhat ou réseau public)
RPC_URL=http://127.0.0.1:8545

# Adresse du contrat déployé (générée par deploy.js)
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Clé privée du compte admin (jamais commiter en production !)
ADMIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Port du serveur Express
PORT=3001

# Environnement : development | production | test
NODE_ENV=development

# Origine autorisée pour CORS (ex: http://localhost:5173)
CORS_ORIGIN=*

# Nombre max de requêtes par 15 minutes (rate limiting)
RATE_LIMIT_MAX=100
